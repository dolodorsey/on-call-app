default_platform(:ios)

platform :ios do
  desc "Build and upload On Call to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_content:   ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false,
      duration:      1200,
      in_house:      false
    )

    increment_build_number(
      build_number:  Time.now.strftime("%Y%m%d%H"),
      xcodeproj:     "App.xcodeproj"
    )

    build_app(
      workspace:        "App.xcworkspace",
      scheme:           "App",
      export_method:    "app-store",
      clean:            true,
      output_directory: "./build",
      output_name:      "on-call.ipa"
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      distribute_external:               false,
      notify_external_testers:           false,
      changelog:                         "KHG Public Launch - On Call"
    )

    UI.success "✅ On Call uploaded to TestFlight!"
    UI.message "Next: appstoreconnect.apple.com → On Call → TestFlight → Enable Public Link"
  end
end
